<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <!-- 我们继承 Material3 的 NoActionBar 主题，去掉默认的顶部标题栏 -->
    <style name="Theme.Webapp" parent="Theme.Material3.DayNight.NoActionBar">
        
        <!-- ================= 核心颜色配置 ================= -->
        
        <!-- 1. 状态栏背景色 (引用刚才定义的白色) -->
        <item name="android:statusBarColor">@color/status_bar_bg</item>
        
        <!-- 2. 状态栏图标颜色 (true表示浅色背景/深色图标，即黑字) -->
        <!-- 如果你的背景是深色，这里要改成 false -->
        <item name="android:windowLightStatusBar">true</item>

        <!-- 3. 去掉各种默认的紫色边框和强调色 -->
        <item name="colorPrimary">@color/brand_color</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_color</item>
        <item name="android:colorBackground">@color/white</item>
        
        <!-- 4. 解决部分手机启动瞬间白屏/黑屏的问题 -->
        <item name="android:windowBackground">@color/white</item>
    </style>
</resources>